generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String?
  nombre         String
  rol            Rol       @default(CONDUCTOR)
  empresaId      String?
  stellarAddress String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  empresa        Empresa?  @relation(fields: [empresaId], references: [id])
  conductor      Conductor?
  sesiones       Session[]

  @@map("users")
}

model Empresa {
  id                String    @id @default(cuid())
  nombre            String
  rfc               String?   @unique
  stellarPublicKey  String    @unique
  escrowContractId  String?
  feeRate           Float     @default(0.003)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  usuarios          User[]
  conductores       Conductor[]
  ubicaciones       Ubicacion[]
  peticiones        PeticionFondo[]
  transacciones     Transaccion[]

  @@map("empresas")
}

model Conductor {
  id                String    @id @default(cuid())
  stellarPublicKey  String    @unique
  limiteCredito    Float     @default(5000)
  usuarioId         String    @unique
  empresaId         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  usuario           User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa           Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  peticiones        PeticionFondo[]

  @@map("conductores")
}

model Ubicacion {
  id          String    @id @default(cuid())
  nombre      String
  direccion   String
  latitud     Float?
  longitud    Float?
  empresaId    String
  createdAt   DateTime  @default(now())

  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  peticiones  PeticionFondo[]

  @@map("ubicaciones")
}

model PeticionFondo {
  id               String          @id @default(cuid())
  conductorId      String
  empresaId        String
  ubicacionId      String?

  montoSolicitado  Float
  montoAprobado   Float?
  estado           EstadoPeticion @default(PENDIENTE)

  tipoCombustible  String
  litros           Float?
  precioLitro      Float?
  motivo           String?

  engagementId     String?
  milestoneIndex   Int?
  txHash          String?
  xdrFirmado      String?

  createdAt        DateTime  @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  completedAt     DateTime?

  conductor        Conductor  @relation(fields: [conductorId], references: [id], onDelete: Cascade)
  empresa          Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  ubicacion        Ubicacion? @relation(fields: [ubicacionId], references: [id])
  transacciones     Transaccion[]

  @@map("peticiones_fondo")
}

model Transaccion {
  id          String              @id @default(cuid())
  empresaId   String
  peticionId  String?

  tipo        TipoTransaccion
  monto       Float
  txHash      String?
  estado      EstadoTransaccion  @default(PENDIENTE)
  feeMonto    Float?

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  empresa     Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  peticion    PeticionFondo?  @relation(fields: [peticionId], references: [id])

  @@map("transacciones")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String   @db.Text
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Rol {
  ADMIN
  CONDUCTOR
}

enum EstadoPeticion {
  PENDIENTE
  APROBADA
  RECHAZADA
  FIRMADA
  COMPLETADA
  FALLIDA
}

enum TipoTransaccion {
  DEPOSITO
  RELEASE
  FEE
}

enum EstadoTransaccion {
  PENDIENTE
  CONFIRMADA
  FALLIDA
}
