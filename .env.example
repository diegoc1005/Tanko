# ═══════════════════════════════════════════════════════════════════════════════
# TANKO - Variables de Entorno
# ═══════════════════════════════════════════════════════════════════════════════
# COPIA este archivo como .env en la raíz del proyecto y configura los valores.
# ═══════════════════════════════════════════════════════════════════════════════

# ── APLICACIÓN ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── STELLAR NETWORK ──────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# ── SOROBAN SMART CONTRACT (Tank Registry) ──────────────────────────────────
# ID del contrato desplegado en Soroban (ej: GXXXXXXXX...XXXX)
SOROBAN_CONTRACT_ID=

# ── TRUSTLESS WORK API ───────────────────────────────────────────────────────
# URL base de la API de Trustless Work
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com
NEXT_PUBLIC_TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com

# API Key de Trustless Work (obtenla en https://app.trustlesswork.com)
TRUSTLESS_WORK_API_KEY=

# ID del Escrow principal (Multi-Release)
ESCROW_ID=

# ── ADMIN WALLET ─────────────────────────────────────────────────────────────
# Secret key del administrador (SOLO PARA BACKEND - NUNCA EXPONER)
TANKO_ADMIN_SECRET=

# ── BASE DE DATOS ─────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tanko_db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Orígenes permitidos (separados por coma)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# ── FRONTEND ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:3001

# WalletConnect / Decaf Wallet (obtenlo en https://cloud.reown.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# NextAuth
NEXTAUTH_SECRET=change_this_to_a_random_string_32_chars
NEXTAUTH_URL=http://localhost:3000
