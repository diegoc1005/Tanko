# ─────────────────────────────────────────────────────────────────────────────
# TANKO – Variables de entorno de ejemplo
# Copia este archivo como .env en la raíz (si usas un proxy) o configura
# cada sub-proyecto con su propio .env según las instrucciones del README.
# ─────────────────────────────────────────────────────────────────────────────

# ── BACKEND (backend/.env) ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL base de la API de Trustless Work
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com

# Tu API Key de Trustless Work (obtenla en https://app.trustlesswork.com)
TRUSTLESS_WORK_API_KEY=

# Red de Stellar ('testnet' para desarrollo, 'public' para producción)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Orígenes permitidos por CORS (separa múltiples con comas, o usa * para desarrollo)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# ── FRONTEND (frontend/.env.local) ───────────────────────────────────────────
# URL del backend Express
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:3001

# NextAuth – genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Conexión a Postgres (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/tanko_db
